  "description": "Production-grade arbitrage bot scanner and executor",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "run": "tsx src/run.ts",
