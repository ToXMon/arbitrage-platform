# RPC Endpoints
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Private Keys (NEVER commit real keys)
ETH_PRIVATE_KEY=0x...
ARB_PRIVATE_KEY=0x...

# Database
POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage_secret
POSTGRES_DB=arbitrage_db
DATABASE_URL=postgresql://arbitrage:arbitrage_secret@postgres:5432/arbitrage_db

# Redis
REDIS_URL=redis://redis:6379

# Flashbots
FLASHBOTS_RELAY=https://relay.flashbots.net

# Logging
LOG_LEVEL=info
NODE_ENV=development
