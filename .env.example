# ============================
# NETWORK MODE: testnet or mainnet
# ============================
NETWORK_MODE=testnet

# ============================
# Sepolia Testnet RPC (default for testing)
# ============================
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_WS=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================
# Mainnet RPC Endpoints (for production)
# ============================
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ============================
# Private Keys (NEVER commit real keys)
# ============================
ETH_PRIVATE_KEY=0x...
ARB_PRIVATE_KEY=0x...

# ============================
# Deployed Contract Addresses
# ============================
# Set after running: npx hardhat run scripts/deploy.js --network sepolia
ARBITRAGE_CONTRACT_ADDRESS=

# ============================
# Database
# ============================
POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage_secret
POSTGRES_DB=arbitrage_db
DATABASE_URL=postgresql://arbitrage:arbitrage_secret@postgres:5432/arbitrage_db

# ============================
# Redis
# ============================
REDIS_URL=redis://redis:6379

# ============================
# Flashbots (mainnet only)
# ============================
FLASHBOTS_RELAY=https://relay.flashbots.net

# ============================
# API & Frontend
# ============================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
JWT_SECRET=change_this_to_a_random_secret
API_KEY=change_this_to_a_random_api_key

# ============================
# Etherscan (for contract verification)
# ============================
ETHERSCAN_API_KEY=

# ============================
# Multi-DEX Pool Discovery
# ============================
# Enable automatic pool discovery via The Graph subgraphs
POOL_DISCOVERY_ENABLED=true

# Minimum pool liquidity in USD (default: $100k)
MIN_POOL_LIQUIDITY=100000

# Maximum pools to fetch per DEX (default: 40)
MAX_POOLS_PER_DEX=40

# Pool refresh interval in milliseconds (default: 10 minutes)
POOL_REFRESH_INTERVAL_MS=600000

# Allowed tokens (comma-separated, leave empty for all tokens)
# Blue-chip tokens: WETH, USDC, USDT, DAI, WBTC
ALLOWED_TOKENS=WETH,USDC,USDT,DAI,WBTC

# ============================
# Flash Loan Configuration
# ============================
# Flash loan provider: 'aave' or 'balancer' (default: aave)
FLASH_LOAN_PROVIDER=aave

# Aave V3 Pool address (mainnet: 0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2)
AAVE_V3_POOL=0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2

# ============================
# Subgraph Endpoints (optional overrides)
# ============================
# UNISWAP_V3_SUBGRAPH=https://api.thegraph.com/subgraphs/name/uniswap/uniswap-v3
# SUSHISWAP_V3_SUBGRAPH=https://api.thegraph.com/subgraphs/name/sushi-v3/v3-ethereum
# BALANCER_V2_SUBGRAPH=https://api.thegraph.com/subgraphs/name/balancer-labs/balancer-v2

# ============================
# Rate Limiting
# ============================
# Maximum subgraph requests per second (default: 1)
SUBGRAPH_MAX_REQUESTS_PER_SECOND=1

# Subgraph request timeout in milliseconds (default: 10000)
SUBGRAPH_TIMEOUT_MS=10000

# ============================
# Logging
# ============================
LOG_LEVEL=info
NODE_ENV=development
